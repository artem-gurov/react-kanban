{
  "name": "react-kanban",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:all": "concurrently \"npm run dev\" \"npm run dev --prefix backend\"",
    "build:shared": "tsc -b shared",
    "build:backend": "tsc -b backend",
    "build:ts": "tsc -b",
    "build": "npm run build:ts && vite build",
