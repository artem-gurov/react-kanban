{
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    "composite": true,
    "lib": ["ES2020"],
    "outDir": "./dist",
    "rootDir": "./src",

    /* Module Resolution */
    "moduleResolution": "node",

    /* Emit */
    "declaration": true,
    "declarationMap": true,

    /* Paths */
    "baseUrl": ".",
    "paths": {
      "@shared/*": ["../shared/*"]
    }
  },
  "references": [{ "path": "../shared" }],
  "include": ["src"],
  "exclude": ["node_modules", "dist", "build", "coverage"]
}
